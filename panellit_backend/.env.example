# Tùy chọn: Chạy ứng dụng trên cổng nào (Mặc định: 3000)
PORT=3000

# Môi trường chạy (development, production, test)
NODE_ENV=development

# --- DATABASE ---
# Cấu hình chuỗi kết nối tới cơ sở dữ liệu PostgreSQL
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Ví dụ:
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/panellit_db?schema=public"

# --- AUTHENTICATION ---
# Chuỗi bí mật dùng để mã hóa JSON Web Token (JWT) cho tính năng đăng nhập
# Tự sinh ra một chuỗi ngẫu nhiên, ví dụ chạy lệnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE"
